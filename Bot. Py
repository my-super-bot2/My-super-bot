import telebot
import os
import yt_dlp
from google import genai

# Tokenlarni xavfsiz joydan olamiz
TOKEN = os.environ.get('BOT_TOKEN')
API_KEY = os.environ.get('GEMINI_KEY')

client = genai.Client(api_key=API_KEY)
bot = telebot.TeleBot(TOKEN)

@bot.message_handler(func=lambda message: True)
def handle_msg(message):
    if message.text.startswith("http"):
        bot.reply_to(message, "⏳ Video tahlil qilinmoqda...")
    else:
        try:
            response = client.models.generate_content(model="gemini-1.5-flash", contents=message.text)
            bot.reply_to(message, response.text)
        except:
            bot.reply_to(message, "Xato! Keyinroq urinib ko'ring.")

if __name__ == "__main__":
    bot.polling(none_stop=True)
